<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Solr config with multiple custom search handlers to exercise migration
  advisor's handler detection and incompatibility flagging.
-->
<config>
  <luceneMatchVersion>8.11.1</luceneMatchVersion>

  <dataDir>${solr.data.dir:}</dataDir>

  <directoryFactory name="DirectoryFactory"
                    class="${solr.directoryFactory:solr.NRTCachingDirectoryFactory}"/>

  <schemaFactory class="ClassicIndexSchemaFactory"/>

  <indexConfig>
    <lockType>${solr.lock.type:native}</lockType>
  </indexConfig>

  <updateHandler class="solr.DirectUpdateHandler2">
    <updateLog>
      <str name="dir">${solr.ulog.dir:}</str>
    </updateLog>
    <autoCommit>
      <maxDocs>10000</maxDocs>
      <maxTime>30000</maxTime>
      <openSearcher>false</openSearcher>
    </autoCommit>
    <autoSoftCommit>
      <maxTime>5000</maxTime>
    </autoSoftCommit>
  </updateHandler>

  <!-- ================================================================ -->
  <!-- Search Handlers — multiple endpoints for migration advisor to    -->
  <!-- discover and flag                                                -->
  <!-- ================================================================ -->

  <!-- Standard select handler -->
  <requestHandler name="/select" class="solr.SearchHandler">
    <lst name="defaults">
      <str name="echoParams">explicit</str>
      <int name="rows">10</int>
      <str name="df">text</str>
    </lst>
  </requestHandler>

  <!-- eDisMax product search — the main search endpoint -->
  <requestHandler name="/product-search" class="solr.SearchHandler">
    <lst name="defaults">
      <str name="defType">edismax</str>
      <str name="qf">name^3 description^1 brand^2 tags^1.5</str>
      <str name="pf">name^5 description^2</str>
      <str name="mm">2&lt;75%</str>
      <str name="bf">linear(popularity,1,0)^0.5</str>
      <int name="rows">20</int>
      <str name="fl">id,name,brand,price,sale_price,rating,in_stock</str>
      <str name="facet">true</str>
      <str name="facet.field">brand</str>
      <str name="facet.field">category</str>
      <str name="facet.range">price</str>
      <str name="f.price.facet.range.start">0</str>
      <str name="f.price.facet.range.end">1000</str>
      <str name="f.price.facet.range.gap">50</str>
    </lst>
  </requestHandler>

  <!-- Autocomplete / suggest handler -->
  <requestHandler name="/suggest" class="solr.SearchHandler">
    <lst name="defaults">
      <str name="defType">edismax</str>
      <str name="qf">name_suggest</str>
      <int name="rows">5</int>
      <str name="fl">id,name</str>
    </lst>
  </requestHandler>

  <!-- Geo-spatial search — nearby warehouse lookup -->
  <requestHandler name="/nearby" class="solr.SearchHandler">
    <lst name="defaults">
      <str name="defType">lucene</str>
      <str name="df">name</str>
      <str name="sfield">warehouse_location</str>
      <str name="fl">id,name,warehouse_location</str>
      <int name="rows">10</int>
    </lst>
  </requestHandler>

  <!-- Update handler -->
  <requestHandler name="/update" class="solr.UpdateRequestHandler"/>

  <requestHandler name="/update/json" class="solr.UpdateRequestHandler">
    <lst name="defaults">
      <str name="stream.contentType">application/json</str>
    </lst>
  </requestHandler>

  <!-- Admin handlers -->
  <requestHandler name="/admin/ping" class="solr.PingRequestHandler">
    <lst name="invariants">
      <str name="q">*:*</str>
    </lst>
  </requestHandler>

  <requestHandler name="/admin/luke" class="org.apache.solr.handler.admin.LukeRequestHandler"/>

  <!-- ================================================================ -->
  <!-- Query parsers                                                    -->
  <!-- ================================================================ -->

  <queryParser name="myparser" class="solr.ExtendedDismaxQParserPlugin"/>

  <!-- ================================================================ -->
  <!-- Caches — sized to produce interesting hit/miss ratios            -->
  <!-- ================================================================ -->

  <query>
    <filterCache class="solr.CaffeineCache"
                 size="256" initialSize="128" autowarmCount="64"/>
    <queryResultCache class="solr.CaffeineCache"
                      size="256" initialSize="128" autowarmCount="32"/>
    <documentCache class="solr.CaffeineCache"
                   size="256" initialSize="128"/>
    <enableLazyFieldLoading>true</enableLazyFieldLoading>
    <maxBooleanClauses>${solr.max.booleanClauses:1024}</maxBooleanClauses>
  </query>

</config>
